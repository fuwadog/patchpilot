# =============================================================================
# PatchPilot Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   copy .env.example .env.local  (Windows)
#   cp .env.example .env.local     (Unix)
#
# Required:
#   OPENAI_API_KEY  - Your NVIDIA/OpenAI-compatible API key
#
# Optional overrides (shown with defaults):
# =============================================================================

# --- Provider Settings ---
# OpenAI-compatible base URL (NVIDIA, OpenAI, Azure, Ollama, LM Studio, etc.)
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# API key (REQUIRED - set this to your actual key)
OPENAI_API_KEY=

# Model name
AI_MODEL=z-ai/glm4.7

# Model temperature (0.0 - 2.0)
AI_TEMPERATURE=0.4

# --- File Loading ---
# Maximum number of files to load from a folder operation
MAX_FILES=12

# Maximum tokens per file when injected into context
MAX_FILE_TOKENS=1500

# Maximum total tokens for the full context window
MAX_TOTAL_TOKENS=4500

# Maximum conversation messages to keep in history
MAX_CONVO_MESSAGES=40

# Maximum tokens per assistant response
MAX_RESPONSE_TOKENS=4096

# --- Safety & Retry ---
# Enable/disable syntax validation before writes
ENABLE_SYNTAX_VALIDATION=false

# Create backup files before applying patches
BACKUP_ON_WRITE=true

# Show unified diff preview before applying patches
DIFF_PREVIEW=true

# Maximum retry attempts for API calls
MAX_RETRIES=3

# Delay between retries (seconds, grows exponentially)
RETRY_DELAY=1.5

# Persistence
PATCHPILOT_DB_PATH=~/.patchpilot/sessions.db
